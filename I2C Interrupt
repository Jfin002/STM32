#include "oled.h"
#include "i2c.h"

#define OLED_ADDR 0x3C

/* Control bytes */
#define OLED_CMD   0x00
#define OLED_DATA  0x40

/* 5x7 Font */
static const uint8_t font5x7[][5] = {
{0x3E,0x51,0x49,0x45,0x3E}, // 0
{0x00,0x42,0x7F,0x40,0x00}, // 1
{0x42,0x61,0x51,0x49,0x46}, // 2
{0x21,0x41,0x45,0x4B,0x31}, // 3
{0x18,0x14,0x12,0x7F,0x10}, // 4
{0x27,0x45,0x45,0x45,0x39}, // 5
{0x3C,0x4A,0x49,0x49,0x30}, // 6
{0x01,0x71,0x09,0x05,0x03}, // 7
{0x36,0x49,0x49,0x49,0x36}, // 8
{0x06,0x49,0x49,0x29,0x1E}  // 9

};

static void OLED_writeCommand(uint8_t cmd)
{
	 while(I2C1_isBusy());
	 I2C1_writeIT(OLED_ADDR, OLED_CMD, &cmd, 1);
}

static void OLED_writeData(uint8_t dataByte)
{
	 while(I2C1_isBusy());
	 I2C1_writeIT(OLED_ADDR, OLED_DATA, &dataByte, 1);
}

void OLED_init(void)
{
    OLED_writeCommand(0xAE);
    OLED_writeCommand(0x20);
    OLED_writeCommand(0x10);
    OLED_writeCommand(0xB0);
    OLED_writeCommand(0xC8);
    OLED_writeCommand(0x00);
    OLED_writeCommand(0x10);
    OLED_writeCommand(0x40);
    OLED_writeCommand(0x81);
    OLED_writeCommand(0x7F);
    OLED_writeCommand(0xA1);
    OLED_writeCommand(0xA6);
    OLED_writeCommand(0xA8);
    OLED_writeCommand(0x3F);
    OLED_writeCommand(0xA4);
    OLED_writeCommand(0xD3);
    OLED_writeCommand(0x00);
    OLED_writeCommand(0xD5);
    OLED_writeCommand(0xF0);
    OLED_writeCommand(0xD9);
    OLED_writeCommand(0x22);
    OLED_writeCommand(0xDA);
    OLED_writeCommand(0x12);
    OLED_writeCommand(0xDB);
    OLED_writeCommand(0x20);
    OLED_writeCommand(0x8D);
    OLED_writeCommand(0x14);
    OLED_writeCommand(0xAF);
    for(volatile int i=0;i<100000;i++);
}

void OLED_clear(void)
{
	OLED_setFullAddress();

	    for(int i = 0; i < 1024; i++)
	        OLED_writeData(0x00);

	    OLED_setCursor(0,0);

}

void OLED_setCursor(uint8_t page, uint8_t column)
{
    OLED_writeCommand(0xB0 + page);
    OLED_writeCommand(0x00 + (column & 0x0F));
    OLED_writeCommand(0x10 + (column >> 4));
}

void OLED_printChar(char c)
{
    if(c < '0' || c > '9') return;

    for(int i=0;i<5;i++)
        OLED_writeData(font5x7[c-'0'][i]);

    OLED_writeData(0x00);
}

void OLED_printString(char *str)
{
    while(*str)
    {
        OLED_printChar(*str);
        str++;
    }
}

void OLED_printNumber(int num)
{
    char buffer[10];
    int i=0;

    if(num == 0)
    {
        OLED_printChar('0');
        return;
    }

    while(num > 0)
    {
        buffer[i++] = (num % 10) + '0';
        num /= 10;
    }

    for(int j=i-1; j>=0; j--)
        OLED_printChar(buffer[j]);
}

static void OLED_setFullAddress(void)
{
    OLED_writeCommand(0x21); // column address
    OLED_writeCommand(0);    // start column
    OLED_writeCommand(127);  // end column

    OLED_writeCommand(0x22); // page address
    OLED_writeCommand(0);    // start page
    OLED_writeCommand(7);    // end page
}

