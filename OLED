#include "stm32f4xx.h"



#define 	GPIOBEN			(1U<<1)
#define 	I2C1EN			(1U<<21)

#define 	I2C_100KHZ						80		//0B 0101 0000 = Decimal = 80
#define 	SD_MODE_MAX_RISE_TIME			17
#define		CR1_PE			(1U<<0)

#define		SR2_BUSY		(1U<<1)
#define     CR1_START		(1U<<8)
#define		SR1_SB			(1U<<0)
#define		SR1_ADDR		(1U<<1)
#define		SR1_TXE			(1U<<7)
#define		CR1_ACK			(1U<<10)
#define     CR1_STOP		(1U<<9)
#define		SR1_RXNE		(1U<<6)
#define	    SR1_BTF			(1U<<2)

/* ---------- GLOBAL STATE ---------- */
static uint8_t *txBuffer;
static uint8_t slaveAddr;
static uint8_t memAddr;
static int txLen;
static int txIndex;
static volatile int txBusy = 0;


/*
 * PB8 ---- SCL
 * PB9 ----- SDA
 * */

void I2C1_init(void)
{
	/*Enable clock access to GPIOB*/
	 RCC->AHB1ENR |=GPIOBEN;

	/*Set PB8 and PB9 mode to alternate function*/
	GPIOB->MODER &=~(1U<<16);
	GPIOB->MODER |=(1U<<17);

	GPIOB->MODER &=~(1U<<18);
	GPIOB->MODER |=(1U<<19);

	/* High speed for I2C pins */
	GPIOB->OSPEEDR |= (1U<<16) | (1U<<17) | (1U<<18) | (1U<<19);

	/*Set PB8 and PB9 output type to  open drain*/
	GPIOB->OTYPER |=(1U<<8);
	GPIOB->OTYPER |=(1U<<9);

	/*Enable Pull-up for PB8 and PB9*/
	GPIOB->PUPDR |=(1U<<16);
	GPIOB->PUPDR &=~(1U<<17);

	GPIOB->PUPDR |=(1U<<18);
	GPIOB->PUPDR &=~(1U<<19);

	/*Set PB8 and PB9 alternate function type to I2C (AF4)*/
	GPIOB->AFR[1] &=~(1U<<0);
	GPIOB->AFR[1] &=~(1U<<1);
	GPIOB->AFR[1] |=(1U<<2);
	GPIOB->AFR[1] &=~(1U<<3);

	GPIOB->AFR[1] &=~(1U<<4);
	GPIOB->AFR[1] &=~(1U<<5);
	GPIOB->AFR[1] |=(1U<<6);
	GPIOB->AFR[1] &=~(1U<<7);


	/*Enable clock access to I2C1*/
	 RCC->APB1ENR |= I2C1EN;

	/*Enter reset mode  */
	I2C1->CR1 |= (1U<<15);

	/*Come out of reset mode  */
	I2C1->CR1 &=~(1U<<15);

	/*Set Peripheral clock frequency*/
	I2C1->CR2 = (1U<<4);   //16 Mhz

	/*Set I2C to standard mode, 100kHz clock */
	I2C1->CCR = I2C_100KHZ;

	/*Set rise time */
	I2C1->TRISE = SD_MODE_MAX_RISE_TIME;



	/* Enable I2C event interrupt */
	I2C1->CR2 |= (1U << 10);   // ITBUFEN  ⭐ REQUIRED
	I2C1->CR2 |= (1U << 9);   // ITEVTEN

	/* Enable I2C error interrupt */
	I2C1->CR2 |= (1U << 8);   // ITERREN

	/* Enable NVIC interrupt */
	NVIC_EnableIRQ(I2C1_EV_IRQn);
	NVIC_EnableIRQ(I2C1_ER_IRQn);

	/*Enable I2C1 module */
	I2C1->CR1 |= CR1_PE;

}

void I2C1_writeIT(char saddr, char maddr, char *data, int len)
{
    while(I2C1->SR2 & SR2_BUSY);
    while(txBusy);

    txBusy = 1;

    slaveAddr = saddr;
    memAddr = maddr;
    txBuffer = data;
    txLen = len;
    txIndex = -2;

    I2C1->CR1 |= CR1_START;
}

int I2C1_isBusy(void)
{
    return txBusy;
}


void I2C1_EV_IRQHandler(void)
{
	 /* START condition sent */
    if(I2C1->SR1 & SR1_SB)
    {
        I2C1->DR = (slaveAddr << 1);
    }
    /* Address sent */
    else if(I2C1->SR1 & SR1_ADDR)
    {
        volatile int tmp = I2C1->SR2;

    }
    /* Data register empty */
    else if(I2C1->SR1 & SR1_TXE)
    {
        if(txIndex == -2)
        {
            I2C1->DR = memAddr;
            txIndex++;
        }
        else if(txIndex == -1)
        {
            I2C1->DR = txBuffer[0];
            txIndex = 1;
        }
        else if(txIndex < txLen)
        {
            I2C1->DR = txBuffer[txIndex++];

        }
        /* Byte transfer finished (safety) */
        else
        {
            I2C1->CR1 |= CR1_STOP;
            txBusy = 0;

        }
    }
}



void I2C1_ER_IRQHandler(void)
{
	    txBusy = 0;
	    I2C1->CR1 |= CR1_STOP;
	    I2C1->SR1 = 0;
}

